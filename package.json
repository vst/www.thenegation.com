{
  "name": "thenegation",
  "version": "2.1.0",
  "description": "vst's Personal Website",
  "author": "Vehbi Sinan Tunalioglu",
  "license": "CC-BY-SA-4.0",
  "homepage": "https://github.com/vst/www.thenegation.com#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vst/www.thenegation.com.git"
  },
  "bugs": {
    "url": "https://github.com/vst/www.thenegation.com/issues"
  },
  "private": true,
  "scripts": {
    "generate:chroma": "hugo gen chromastyles --style=catppuccin-latte > assets/css/chroma-latte.css && hugo gen chromastyles --style=catppuccin-mocha > assets/css/chroma-mocha.css",
    "generate:fonts": "./scripts/fetch-fonts.sh",
    "generate": "pnpm run generate:chroma && pnpm run generate:fonts",
    "dev": "pnpm run generate && hugo server",
    "format:prettier": "prettier --write .",
    "format": "pnpm run format:prettier",
    "check:format:prettier": "prettier --check .",
    "check:format": "pnpm run check:format:prettier",
    "check:types": "tsc --noEmit",
    "check": "pnpm run check:format && pnpm run check:types && pnpm run build",
    "build:hugo": "pnpm run generate && hugo build --gc --minify",
    "build:pagefind": "pnpm exec pagefind --site public",
    "build": "pnpm run build:hugo && pnpm run build:pagefind"
  },
  "devDependencies": {
    "@catppuccin/tailwindcss": "^1.0.0",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.5",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2"
  },
  "prettier": {
    "printWidth": 80,
    "proseWrap": "always",
    "plugins": [
      "prettier-plugin-go-template",
      "prettier-plugin-tailwindcss"
    ],
    "overrides": [
      {
        "files": [
          "*.html"
        ],
        "options": {
          "parser": "go-template",
          "goTemplateBracketSpacing": true,
          "bracketSameLine": true
        }
      },
      {
        "files": [
          "*.js",
          "*.ts"
        ],
        "options": {
          "useTabs": false,
          "singleQuote": false
        }
      }
    ]
  }
}
